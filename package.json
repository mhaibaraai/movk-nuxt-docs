{
  "name": "nuxt-docs-workspace",
  "type": "module",
  "version": "1.19.6",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "license": "MIT",
  "homepage": "https://docs.mhaibaraai.cn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhaibaraai/movk-nuxt-docs.git"
  },
  "sideEffects": false,
  "scripts": {
    "postinstall": "pnpm dev:prepare",
    "build": "nuxt build docs --extends ../layer",
    "dev": "nuxt dev docs --extends ../layer",
    "dev:prepare": "nuxt prepare layer && nuxt prepare docs --extends ../layer",
    "release": "pnpm release:layer && release-it",
    "release:layer": "release-it --config .release-it.layer.json && cd layer && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck layer",
    "clean": "movk-clean"
  },
  "devDependencies": {
    "@movk/core": "^1.3.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@release-it/bumper": "^7.0.6",
    "@release-it/conventional-changelog": "^11.0.1",
    "eslint": "^10.4.1",
    "nuxt": "4.4.6",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.3"
  }
}
